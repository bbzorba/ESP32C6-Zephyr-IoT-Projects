/*
 * Board overlay for ESP32-C6-DevKitC HP Core
 *
 * Defines led0–led3 aliases required by the BME688 application.
 *
 * led0 → GPIO8  (onboard LED pin; WS2812 on DevKitC-1 v1.2, plain LED on v1.0)
 * led1 → GPIO4  (external LED, active-high)
 * led2 → GPIO5  (external LED, active-high)
 * led3 → GPIO10 (external LED, active-high)
 *
 * The button alias sw0 is already provided by the board DTS (GPIO9, BOOT key).
 */

/ {
	aliases {
		led0 = &led0;
		led1 = &led1;
		led2 = &led2;
		led3 = &led3;
	};

	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpio0 8 GPIO_ACTIVE_HIGH>;
			label = "LED 0";
		};

		led1: led_1 {
			gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
			label = "LED 1";
		};

		led2: led_2 {
			gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>;
			label = "LED 2";
		};

		led3: led_3 {
			gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
			label = "LED 3";
		};
	};
};
