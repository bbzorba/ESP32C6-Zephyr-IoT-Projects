{
  "version": "0.2.0",
  "configurations": [
    {
      // ── Active-app debug (project/board come from gen-debug-context) ──────
      // gen-debug-context (run as part of debug-prep) copies the built ELF to
      // .vscode/zephyr.elf and writes .vscode/board_cfg.tcl that sources the
      // correct board openocd.cfg.  Only machine-specific paths (GDB binary,
      // OpenOCD binary) are read from settings.json via ${config:...} — those
      // never change between projects, only between machines.
      "name": "Debug: Active App (from Makefile)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "debug-prep",
      "executable": "${workspaceFolder}/.vscode/zephyr.elf",
      "configFiles": [
        "${workspaceFolder}/.vscode/board_cfg.tcl",
        "${workspaceFolder}/.vscode/openocd_fixup.tcl"
      ],
      "gdbPath": "${config:zephyr.gdbPath}",
      "svdFile": "",
      "loadFiles": [],
      "hardwareBreakpoints": { "enabled": true, "limit": 4 },
      "overrideLaunchCommands": [
        "monitor reset halt",
        "monitor esp appimage_offset 0x0"
      ],
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw"
    }
  ]
}
