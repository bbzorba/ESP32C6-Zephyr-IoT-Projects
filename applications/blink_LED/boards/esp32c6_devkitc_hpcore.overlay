/*
 * Board overlay for ESP32-C6-DevKitC HP Core
 *
 * GPIO8 onboard LED is a WS2812B RGB LED driven via I2S — NOT a plain GPIO.
 * It is configured here using the worldsemi,ws2812-i2s driver.
 *
 * led-strip → WS2812B on GPIO8  (onboard RGB LED, I2S driven)
 * led1      → GPIO4  (external plain LED, active-high)
 * led2      → GPIO5  (external plain LED, active-high)
 * led3      → GPIO10 (external plain LED, active-high)
 */

#include <zephyr/dt-bindings/led/led.h>

/ {
	aliases {
		led-strip = &led_strip;
		led1 = &led1;
		led2 = &led2;
		led3 = &led3;
	};

	leds {
		compatible = "gpio-leds";

		led1: led_1 {
			gpios = <&gpio0 4 GPIO_ACTIVE_HIGH>;
			label = "LED 1";
		};

		led2: led_2 {
			gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>;
			label = "LED 2";
		};

		led3: led_3 {
			gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
			label = "LED 3";
		};
	};
};

/* Override I2S pinctrl: only GPIO8 as data output (WS2812 doesn't need CLK/WS) */
&i2s_default {
	group1 {
		pinmux = <I2S_O_SD_GPIO8>;
	};
};

/* WS2812B RGB LED on GPIO8, driven via I2S + DMA */
i2s_led: &i2s {
	status = "okay";

	dmas = <&dma 3>;
	dma-names = "tx";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-i2s";

		reg = <0>;
		chain-length = <1>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
		reset-delay = <500>;
	};
};

&dma {
	status = "okay";
};
